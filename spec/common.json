{
  "definitions": {
    "Collection": {
      "description": "Base collection",
      "type": "struct",
      "properties": {
        "totalResults": {
          "type": "integer"
        },
        "startIndex": {
          "type": "integer"
        },
        "itemsPerPage": {
          "type": "integer"
        },
        "entry": {
          "type": "array",
          "schema": {
            "type": "generic",
            "name": "T"
          }
        }
      }
    },
    "Message": {
      "description": "Common error message",
      "type": "struct",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      }
    },
    "Metadata": {
      "type": "map",
      "schema": {
        "type": "string"
      }
    },
    "Form_Container": {
      "description": "Represents a config form with a list of elements",
      "type": "struct",
      "properties": {
        "element": {
          "type": "array",
          "schema": {
            "type": "reference",
            "target": "Form_Element"
          }
        }
      }
    },
    "Form_Element": {
      "description": "Form base element",
      "type": "struct",
      "base": true,
      "discriminator": "type",
      "mapping": {
        "Form_Element_Checkbox": "checkbox",
        "Form_Element_Collection": "collection",
        "Form_Element_Input": "input",
        "Form_Element_Map": "map",
        "Form_Element_Select": "select",
        "Form_Element_TextArea": "textarea",
        "Form_Element_TypeAPI": "typeapi",
        "Form_Element_TypeSchema": "typeschema"
      },
      "properties": {
        "element": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "help": {
          "type": "string"
        }
      }
    },
    "Form_Element_Checkbox": {
      "description": "Form element which represents a checkbox element",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element"
      }
    },
    "Form_Element_Collection": {
      "description": "Form element which represents a collection element",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element_Input"
      }
    },
    "Form_Element_Input": {
      "description": "Form element which represents an input element",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element"
      },
      "properties": {
        "type": {
          "description": "The input type i.e. text or password, all HTML input types are allowed",
          "type": "string"
        }
      }
    },
    "Form_Element_Map": {
      "description": "Form element which represents a map element",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element_Input"
      }
    },
    "Form_Element_Select": {
      "description": "Form element which represents a select element",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element"
      },
      "properties": {
        "options": {
          "description": "Available options for the select element",
          "type": "array",
          "schema": {
            "type": "reference",
            "target": "Form_Element_Select_Option"
          }
        }
      }
    },
    "Form_Element_Select_Option": {
      "description": "Represents a concrete option entry",
      "type": "struct",
      "properties": {
        "key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "Form_Element_TextArea": {
      "description": "Form element which represents a textarea",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element"
      },
      "properties": {
        "mode": {
          "description": "Describes which data is provided at the textarea, this can be i.e. a programming language like php, java or python or also a data format like json",
          "type": "string"
        }
      }
    },
    "Form_Element_TypeAPI": {
      "description": "Form element which represents a TypeAPI editor",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element"
      }
    },
    "Form_Element_TypeSchema": {
      "description": "Form element which represents a TypeSchema editor",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Form_Element"
      }
    },
    "Agent_Input": {
      "description": "This object represents an agent input",
      "type": "struct",
      "properties": {
        "previousId": {
          "description": "Optional the previous input id, must be an id which has been previously returned by an output",
          "type": "string"
        },
        "input": {
          "description": "The input",
          "type": "reference",
          "target": "Agent_Content"
        }
      }
    },
    "Agent_Output": {
      "description": "This object represents an agent output",
      "type": "struct",
      "properties": {
        "id": {
          "description": "Available if the message was persisted",
          "type": "string"
        },
        "output": {
          "description": "The output",
          "type": "reference",
          "target": "Agent_Content"
        }
      }
    },
    "Agent_Content": {
      "description": "Agent message",
      "type": "struct",
      "base": true,
      "discriminator": "type",
      "mapping": {
        "Agent_Content_Binary": "binary",
        "Agent_Content_Choice": "choice",
        "Agent_Content_Object": "object",
        "Agent_Content_Text": "text",
        "Agent_Content_ToolCall": "tool_call"
      },
      "properties": {
        "type": {
          "description": "The result type",
          "type": "string"
        },
        "metadata": {
          "description": "Optional result metadata",
          "type": "map",
          "schema": {
            "type": "any"
          }
        }
      }
    },
    "Agent_Content_Binary": {
      "description": "Binary agent message",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Agent_Content"
      },
      "properties": {
        "mime": {
          "description": "The mime of the binary data",
          "type": "string"
        },
        "data": {
          "description": "The base64 encoded binary data",
          "type": "string"
        }
      }
    },
    "Agent_Content_Choice": {
      "description": "Choice agent message",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Agent_Content"
      },
      "properties": {
        "items": {
          "description": "Contains multiple agent messages",
          "type": "array",
          "schema": {
            "type": "reference",
            "target": "Agent_Content"
          }
        }
      }
    },
    "Agent_Content_Object": {
      "description": "Structured agent message",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Agent_Content"
      },
      "properties": {
        "payload": {
          "description": "The structured JSON payload",
          "type": "any"
        }
      }
    },
    "Agent_Content_Text": {
      "description": "Text agent message",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Agent_Content"
      },
      "properties": {
        "content": {
          "description": "The content text",
          "type": "string"
        }
      }
    },
    "Agent_Content_ToolCall": {
      "description": "Tool call agent message",
      "type": "struct",
      "parent": {
        "type": "reference",
        "target": "Agent_Content"
      },
      "properties": {
        "functions": {
          "description": "An array of concrete functions",
          "type": "array",
          "schema": {
            "type": "reference",
            "target": "Agent_Content_ToolCall_Function"
          }
        }
      }
    },
    "Agent_Content_ToolCall_Function": {
      "description": "Concrete values for a function tool call",
      "type": "struct",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "arguments": {
          "type": "string"
        }
      }
    }
  }
}
